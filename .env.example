APP_ENV=production
APP_DEBUG=false
APP_KEY=

APP_NAME="InvoiceShelf"
APP_TIMEZONE=UTC
APP_URL=
APP_LOCALE=en

DB_CONNECTION=sqlite
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_STRICT_MODE=true

SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAIN=
TRUSTED_PROXIES=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_EXPIRE_ON_CLOSE=true
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
CRON_JOB_AUTH_TOKEN=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Slow API request timing log (disabled by default)
REQUEST_TIMING_LOG_ENABLED=false
REQUEST_TIMING_LOG_THRESHOLD_MS=200
